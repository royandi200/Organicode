{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/lotes/:slug", "destination": "/api/lotes/[slug]" },
    { "source": "/api/precios/actual", "destination": "/api/precios/actual" },
    { "source": "/api/admin/ofertas/:id", "destination": "/api/admin/ofertas/[id]" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api|assets|favicon\\.ico|robots\\.txt).*)", "destination": "/index.html" }
  ]
}
